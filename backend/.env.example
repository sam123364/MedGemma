# Runtime: mock | mlx | ollama
MEDGEMMA_RUNTIME=mock

# MedGemma model name or path
MEDGEMMA_MODEL=google/medgemma-27b-it

# MLX server endpoint (OpenAI-compatible chat endpoint)
MEDGEMMA_MLX_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
MEDGEMMA_TIMEOUT_SECONDS=300
MEDGEMMA_MAX_TOKENS=900

# Ollama endpoint/model if using ollama runtime
MEDGEMMA_OLLAMA_URL=http://127.0.0.1:11434/api/generate
MEDGEMMA_OLLAMA_MODEL=medgemma

ASTRA_DB_PATH=./data/astra.db
ASTRA_CHROMA_PATH=./data/chroma

SIM_HORIZON_DAYS=180
COARSE_TRIALS=1000
HIGH_FIDELITY_COUNT=5
POPULATION_MAP_TRIALS=120

AUTO_RESUME_INCOMPLETE_RUNS=false
ASTRA_FAIL_AFTER_NODE=
ALEMBIC_HEAD_REVISION=20260224_0001
ENFORCE_ALEMBIC_HEAD=true

CORS_ORIGINS=http://localhost:3000
